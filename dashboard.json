{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    },
    {
      "name": "DS_LOKI",
      "label": "Loki",
      "type": "datasource",
      "pluginId": "loki",
      "pluginName": "Loki"
    }
  ],
  "__requires": [
    { "type": "grafana",    "id": "grafana",    "name": "Grafana",    "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "datasource", "id": "loki",       "name": "Loki",       "version": "1.0.0" },
    { "type": "panel",      "id": "stat",       "name": "Stat",       "version": "" },
    { "type": "panel",      "id": "timeseries", "name": "Time series","version": "" },
    { "type": "panel",      "id": "logs",       "name": "Logs",       "version": "" }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Nexus AgenticAI — HTTP metrics (Prometheus) + pod logs (Loki). Works with external docker-compose observability stack.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["nexus", "kubernetes", "microservices", "fastapi"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "name": "prometheus_datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource",
        "label": "Prometheus"
      },
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "name": "loki_datasource",
        "options": [],
        "query": "loki",
        "refresh": 1,
        "type": "datasource",
        "label": "Loki"
      },
      {
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "${prometheus_datasource}" },
        "definition": "label_values(http_requests_total, service)",
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "name": "service",
        "query": {
          "query": "label_values(http_requests_total, service)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "sort": 1,
        "type": "query",
        "label": "Service"
      },
      {
        "current": { "selected": true, "text": "5m", "value": "5m" },
        "hide": 0,
        "includeAll": false,
        "name": "rate_interval",
        "options": [
          { "selected": false, "text": "1m",  "value": "1m"  },
          { "selected": true,  "text": "5m",  "value": "5m"  },
          { "selected": false, "text": "10m", "value": "10m" },
          { "selected": false, "text": "30m", "value": "30m" }
        ],
        "query": "1m,5m,10m,30m",
        "type": "custom",
        "label": "Rate Interval"
      }
    ]
  },
  "time": { "from": "now-3h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Nexus AgenticAI — Microservices",
  "uid": "nexus-microservices-v1",
  "version": 1,
  "panels": [

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }, "id": 1, "title": "Overview", "type": "row" },

    {
      "datasource": { "type": "prometheus", "uid": "${prometheus_datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 50 }, { "color": "red", "value": 200 }] },
          "unit": "reqps", "mappings": []
        }, "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 }, "id": 2,
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "title": "Total Request Rate", "type": "stat",
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${prometheus_datasource}" }, "expr": "sum(rate(http_requests_total{service=~\"$service\"}[$rate_interval]))", "legendFormat": "RPS", "refId": "A" }]
    },

    {
      "datasource": { "type": "prometheus", "uid": "${prometheus_datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 5 }] },
          "unit": "percent", "max": 100, "min": 0
        }, "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 }, "id": 3,
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "title": "Overall Error Rate", "type": "stat",
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${prometheus_datasource}" }, "expr": "100 * sum(rate(http_requests_total{service=~\"$service\", status_code=~\"5..\"}[$rate_interval])) / sum(rate(http_requests_total{service=~\"$service\"}[$rate_interval]))", "legendFormat": "Error %", "refId": "A" }]
    },

    {
      "datasource": { "type": "prometheus", "uid": "${prometheus_datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.5 }, { "color": "red", "value": 2 }] },
          "unit": "s"
        }, "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 }, "id": 4,
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "title": "P95 Latency (all services)", "type": "stat",
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${prometheus_datasource}" }, "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{service=~\"$service\"}[$rate_interval])) by (le))", "legendFormat": "p95", "refId": "A" }]
    },

    {
      "datasource": { "type": "prometheus", "uid": "${prometheus_datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 1 }, { "color": "green", "value": 2 }] },
          "unit": "short"
        }, "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 }, "id": 5,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "title": "Services Up", "type": "stat",
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${prometheus_datasource}" }, "expr": "count(up{job=~\"intent-agent|sql-query-generator|sql-validator\"} == 1)", "legendFormat": "Up", "refId": "A" }]
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 }, "id": 10, "title": "Request Rates", "type": "row" },

    {
      "datasource": { "type": "prometheus", "uid": "${prometheus_datasource}" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 10, "showPoints": "never", "spanNulls": true }, "unit": "reqps" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 6 }, "id": 11,
      "options": { "legend": { "calcs": ["mean", "max", "lastNotNull"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "title": "HTTP Request Rate — per Service", "type": "timeseries",
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${prometheus_datasource}" }, "expr": "sum by (service) (rate(http_requests_total{service=~\"$service\"}[$rate_interval]))", "legendFormat": "{{ service }}", "refId": "A" }]
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 }, "id": 20, "title": "Latency", "type": "row" },

    {
      "datasource": { "type": "prometheus", "uid": "${prometheus_datasource}" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 5, "showPoints": "never", "spanNulls": true }, "unit": "s" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 }, "id": 21,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "title": "Latency Percentiles — Intent Agent", "type": "timeseries",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${prometheus_datasource}" }, "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{job=\"intent-agent\"}[$rate_interval])) by (le))", "legendFormat": "p50", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "${prometheus_datasource}" }, "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"intent-agent\"}[$rate_interval])) by (le))", "legendFormat": "p95", "refId": "B" },
        { "datasource": { "type": "prometheus", "uid": "${prometheus_datasource}" }, "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{job=\"intent-agent\"}[$rate_interval])) by (le))", "legendFormat": "p99", "refId": "C" }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "${prometheus_datasource}" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 5, "showPoints": "never", "spanNulls": true }, "unit": "s" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 }, "id": 22,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "title": "Latency Percentiles — SQL Query Generator", "type": "timeseries",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${prometheus_datasource}" }, "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{job=\"sql-query-generator\"}[$rate_interval])) by (le))", "legendFormat": "p50", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "${prometheus_datasource}" }, "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"sql-query-generator\"}[$rate_interval])) by (le))", "legendFormat": "p95", "refId": "B" },
        { "datasource": { "type": "prometheus", "uid": "${prometheus_datasource}" }, "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{job=\"sql-query-generator\"}[$rate_interval])) by (le))", "legendFormat": "p99", "refId": "C" }
      ]
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 }, "id": 30, "title": "Error Analysis", "type": "row" },

    {
      "datasource": { "type": "prometheus", "uid": "${prometheus_datasource}" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 15, "showPoints": "never", "spanNulls": true }, "unit": "reqps" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 }, "id": 31,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "title": "4xx Client Errors — per Service", "type": "timeseries",
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${prometheus_datasource}" }, "expr": "sum by (service) (rate(http_requests_total{service=~\"$service\", status_code=~\"4..\"}[$rate_interval]))", "legendFormat": "{{ service }} 4xx", "refId": "A" }]
    },

    {
      "datasource": { "type": "prometheus", "uid": "${prometheus_datasource}" },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "red" }, "custom": { "lineWidth": 2, "fillOpacity": 20, "showPoints": "never", "spanNulls": true }, "unit": "reqps" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 }, "id": 32,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "title": "5xx Server Errors — per Service", "type": "timeseries",
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${prometheus_datasource}" }, "expr": "sum by (service) (rate(http_requests_total{service=~\"$service\", status_code=~\"5..\"}[$rate_interval]))", "legendFormat": "{{ service }} 5xx", "refId": "A" }]
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 32 }, "id": 40, "title": "Endpoint Breakdown", "type": "row" },

    {
      "datasource": { "type": "prometheus", "uid": "${prometheus_datasource}" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 5, "showPoints": "never", "spanNulls": true }, "unit": "reqps" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 33 }, "id": 41,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "title": "Intent Agent — by Endpoint", "type": "timeseries",
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${prometheus_datasource}" }, "expr": "sum by (handler) (rate(http_requests_total{job=\"intent-agent\"}[$rate_interval]))", "legendFormat": "{{ handler }}", "refId": "A" }]
    },

    {
      "datasource": { "type": "prometheus", "uid": "${prometheus_datasource}" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 5, "showPoints": "never", "spanNulls": true }, "unit": "reqps" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 33 }, "id": 42,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "title": "SQL Query Generator — by Endpoint", "type": "timeseries",
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${prometheus_datasource}" }, "expr": "sum by (handler) (rate(http_requests_total{job=\"sql-query-generator\"}[$rate_interval]))", "legendFormat": "{{ handler }}", "refId": "A" }]
    },

    {
      "datasource": { "type": "prometheus", "uid": "${prometheus_datasource}" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 5, "showPoints": "never", "spanNulls": true }, "unit": "reqps" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 33 }, "id": 43,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "title": "SQL Validator — by Endpoint", "type": "timeseries",
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${prometheus_datasource}" }, "expr": "sum by (handler) (rate(http_requests_total{job=\"sql-validator\"}[$rate_interval]))", "legendFormat": "{{ handler }}", "refId": "A" }]
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 41 }, "id": 50, "title": "Application Logs", "type": "row" },

    {
      "datasource": { "type": "loki", "uid": "${loki_datasource}" },
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 42 }, "id": 51,
      "options": { "dedupStrategy": "none", "enableLogDetails": true, "prettifyLogMessage": false, "showCommonLabels": false, "showLabels": true, "showTime": true, "sortOrder": "Descending", "wrapLogMessage": false },
      "title": "All Service Logs", "type": "logs",
      "targets": [{ "datasource": { "type": "loki", "uid": "${loki_datasource}" }, "expr": "{cluster=\"nexus-k8s\", service=~\"$service\"}", "legendFormat": "", "refId": "A" }]
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 54 }, "id": 60, "title": "Error Logs", "type": "row" },

    {
      "datasource": { "type": "loki", "uid": "${loki_datasource}" },
      "gridPos": { "h": 12, "w": 12, "x": 0, "y": 55 }, "id": 61,
      "options": { "dedupStrategy": "none", "enableLogDetails": true, "prettifyLogMessage": false, "showCommonLabels": false, "showLabels": true, "showTime": true, "sortOrder": "Descending", "wrapLogMessage": false },
      "title": "ERROR Logs — All Services", "type": "logs",
      "targets": [{ "datasource": { "type": "loki", "uid": "${loki_datasource}" }, "expr": "{cluster=\"nexus-k8s\", service=~\"$service\"} |= \"ERROR\"", "legendFormat": "", "refId": "A" }]
    },

    {
      "datasource": { "type": "loki", "uid": "${loki_datasource}" },
      "gridPos": { "h": 12, "w": 12, "x": 12, "y": 55 }, "id": 62,
      "options": { "dedupStrategy": "none", "enableLogDetails": true, "prettifyLogMessage": false, "showCommonLabels": false, "showLabels": true, "showTime": true, "sortOrder": "Descending", "wrapLogMessage": false },
      "title": "Exception / Traceback Logs", "type": "logs",
      "targets": [{ "datasource": { "type": "loki", "uid": "${loki_datasource}" }, "expr": "{cluster=\"nexus-k8s\", service=~\"$service\"} |~ \"(Exception|Traceback|HTTPException|500)\"", "legendFormat": "", "refId": "A" }]
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 67 }, "id": 70, "title": "Log Volume", "type": "row" },

    {
      "datasource": { "type": "loki", "uid": "${loki_datasource}" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 1, "fillOpacity": 30, "showPoints": "never", "spanNulls": true, "drawStyle": "bars", "barAlignment": 0 }, "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 68 }, "id": 71,
      "options": { "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "title": "Log Lines per Minute — per Service", "type": "timeseries",
      "targets": [{ "datasource": { "type": "loki", "uid": "${loki_datasource}" }, "expr": "sum by (service) (rate({cluster=\"nexus-k8s\", service=~\"$service\"}[1m]))", "legendFormat": "{{ service }}", "refId": "A" }]
    },

    {
      "datasource": { "type": "loki", "uid": "${loki_datasource}" },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "red" }, "custom": { "lineWidth": 1, "fillOpacity": 30, "showPoints": "never", "spanNulls": true, "drawStyle": "bars", "barAlignment": 0 }, "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 68 }, "id": 72,
      "options": { "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "title": "Error Log Lines per Minute — per Service", "type": "timeseries",
      "targets": [{ "datasource": { "type": "loki", "uid": "${loki_datasource}" }, "expr": "sum by (service) (rate({cluster=\"nexus-k8s\", service=~\"$service\"} |~ \"(?i)(error|exception|traceback)\"[1m]))", "legendFormat": "{{ service }} errors", "refId": "A" }]
    }

  ]
}
