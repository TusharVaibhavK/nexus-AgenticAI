// ============================================================
// Grafana Alloy — config.alloy
// Nexus AgenticAI  |  Docker Compose monitoring stack
//
// Collects logs from:
//   1. Local Docker containers on this monitoring VM
//   2. Kubernetes pod logs via the K8s API  ← requires kubeconfig
//      mounted at /etc/alloy/kubeconfig
//
// Both streams are forwarded to the local Loki instance.
// ============================================================

logging {
  level  = "info"
  format = "logfmt"
}

livedebugging {
  enabled = true
}

// ──────────────────────────────────────────────────────────────
// 1. LOCAL DOCKER CONTAINERS
//    Discovers all containers running on this VM via the Docker
//    socket and ships their logs to Loki with a 'container' label.
// ──────────────────────────────────────────────────────────────

discovery.docker "local_containers" {
  host             = "unix:///var/run/docker.sock"
  refresh_interval = "5s"
}

discovery.relabel "docker_logs" {
  targets = discovery.docker.local_containers.targets

  // Strip leading slash from container name  →  "prometheus" not "/prometheus"
  rule {
    source_labels = ["__meta_docker_container_name"]
    regex         = "/(.*)"
    target_label  = "container"
  }

  // Promote the compose service label so dashboards can filter by service name
  rule {
    source_labels = ["__meta_docker_compose_service"]
    target_label  = "service"
  }
}

loki.source.docker "local_containers" {
  host          = "unix:///var/run/docker.sock"
  targets       = discovery.docker.local_containers.targets
  forward_to    = [loki.process.docker_logs.receiver]
  relabel_rules = discovery.relabel.docker_logs.rules
}

loki.process "docker_logs" {
  // Attempt to parse JSON-structured lines (e.g. structured logger output)
  stage.json {
    expressions = {
      level   = "level",
      message = "message",
      msg     = "msg",
    }
  }

  // Promote parsed 'level' to a real Loki label for easy filtering
  stage.labels {
    values = {
      level = "",
    }
  }

  stage.static_labels {
    values = {
      env     = "production",
      cluster = "monitoring-vm",
    }
  }

  forward_to = [loki.write.loki_local.receiver]
}

// ──────────────────────────────────────────────────────────────
// 2. KUBERNETES POD LOGS
//    Discovers pods via the K8s API and tails their log files.
//
//    Prerequisites:
//      a) Mount your kubeconfig into the Alloy container:
//         Add to docker-compose.yml under alloy.volumes:
//           - ~/.kube/config:/etc/alloy/kubeconfig:ro
//
//      b) The K8s node's /var/log/pods path must be accessible.
//         This works when Alloy runs ON the K8s node itself.
//         If Prometheus/Alloy run on a SEPARATE VM, deploy the
//         lightweight in-cluster log forwarder instead:
//           kubectl apply -f kubernetes/monitoring/alloy-k8s-logforwarder.yaml
//         That DaemonSet pushes directly to:
//           http://<THIS_VM_IP>:3100/loki/api/v1/push
// ──────────────────────────────────────────────────────────────

discovery.kubernetes "k8s_pods" {
  role            = "pod"
  kubeconfig_file = "/etc/alloy/kubeconfig"
}

discovery.relabel "k8s_pod_logs" {
  targets = discovery.kubernetes.k8s_pods.targets

  // Drop non-running pods
  rule {
    source_labels = ["__meta_kubernetes_pod_phase"]
    regex         = "Pending|Succeeded|Failed|Unknown"
    action        = "drop"
  }

  // Build the log file path on the node:
  //   /var/log/pods/<namespace>_<pod>_<uid>/<container>/*.log
  rule {
    source_labels = [
      "__meta_kubernetes_pod_namespace",
      "__meta_kubernetes_pod_name",
      "__meta_kubernetes_pod_uid",
      "__meta_kubernetes_pod_container_name",
    ]
    separator    = "/"
    target_label = "__path__"
    replacement  = "/var/log/pods/$1_$2_$3/$4/*.log"
  }

  rule {
    source_labels = ["__meta_kubernetes_pod_namespace"]
    target_label  = "namespace"
  }

  rule {
    source_labels = ["__meta_kubernetes_pod_name"]
    target_label  = "pod"
  }

  rule {
    source_labels = ["__meta_kubernetes_pod_container_name"]
    target_label  = "container"
  }

  // Use the pod's 'app' label as the service name (matches Nexus deployments)
  rule {
    source_labels = ["__meta_kubernetes_pod_label_app"]
    target_label  = "service"
  }

  rule {
    source_labels = ["__meta_kubernetes_pod_node_name"]
    target_label  = "node"
  }
}

loki.source.file "k8s_pod_logs" {
  targets    = discovery.relabel.k8s_pod_logs.output
  forward_to = [loki.process.k8s_logs.receiver]
}

loki.process "k8s_logs" {
  stage.json {
    expressions = {
      level   = "level",
      message = "message",
      msg     = "msg",
    }
  }

  stage.labels {
    values = {
      level = "",
    }
  }

  stage.drop {
    expression          = "^\\s*$"
    drop_counter_reason = "empty_line"
  }

  stage.static_labels {
    values = {
      env     = "production",
      cluster = "nexus-k8s",
    }
  }

  forward_to = [loki.write.loki_local.receiver]
}

// ──────────────────────────────────────────────────────────────
// 3. LOKI WRITE ENDPOINT
//    Single shared sink — both pipelines above write here.
// ──────────────────────────────────────────────────────────────

loki.write "loki_local" {
  endpoint {
    url = "http://loki:3100/loki/api/v1/push"
  }
}
